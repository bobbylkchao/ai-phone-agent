{
  "name": "ai-phone-agent",
  "version": "0.0.1",
  "main": "dist/index.js",
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "compile": "tsc && tsc-alias -p tsconfig.json",
    "start": "npm run compile && node ./dist/index.js",
    "build": "npm run compile",
    "dev": "nodemon",
    "lint": "eslint --config ./eslint.config.mjs src --fix",
    "lint:ci": "eslint --config ./eslint.config.mjs src --max-warnings 0",
    "format": "prettier --config .prettierrc \"src/**/*.ts\" --write",
    "version": "npx standard-version --skip.tag --skip.commit --release-as patch"
  },
  "keywords": [
    "ai-phone-agent",
    "openai",
    "realtime",
    "twilio",
    "amazon-connect",
    "voice-agent",
    "pstn",
    "sip"
  ],
  "author": "",
  "license": "MIT",
  "description": "OpenAI Realtime phone agent server (Twilio PSTN + Amazon Connect SIP)",
  "dependencies": {
    "@aws-sdk/client-connect": "^3.1019.0",
    "@modelcontextprotocol/sdk": "^1.20.2",
    "@openai/agents": "^0.1.11",
    "@openai/agents-extensions": "^0.2.1",
    "@types/ws": "^8.18.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "openai": "^6.6.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "typescript": "^5.6.3",
    "ws": "^8.18.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.38.0",
    "@kesills/eslint-config-airbnb-typescript": "^20.0.0",
    "@stylistic/eslint-plugin": "^2.13.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.8.5",
    "eslint": "^9.39.4",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^15.12.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.46.2"
  }
}
